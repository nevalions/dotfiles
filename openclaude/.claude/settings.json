{
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "Bash(claude mcp:*)",
      "Bash(stow:*)",
      "Bash(cp:*)",
      "WebSearch",
      "mcp__vikunja__*",
      "mcp__forgejo__*",
      "mcp__perplexity__*",
      "mcp__context7__*",
      "mcp__vibe-check-mcp__*",
      "Grep"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "beads@beads-marketplace": true
  },
  "extraKnownMarketplaces": {
    "beads-marketplace": {
      "source": {
        "source": "github",
        "repo": "steveyegge/beads"
      }
    }
  }
}
